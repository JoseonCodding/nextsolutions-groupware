<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.kdt.mapper.login">

    <!-- 다음 사원번호(emp_seq) 구하기 -->
    <select id="getNextEmpSeq" resultType="int">
        SELECT COALESCE(MAX(emp_seq), 0) + 1
        FROM employee
    </select>

    <!-- 회원 저장 -->
    <insert id="saveProc" parameterType="CmmnMap">
        INSERT INTO employee (emp_seq, employeeId, password)
        VALUES (#{emp_seq}, #{employeeId}, #{password})
    </insert>

    <!-- 회원 목록 -->
    <select id="getUserList" resultType="CmmnMap">
        SELECT * FROM employee
    </select>

    <!-- 회원 정보 수정 -->
    <update id="updateUser" parameterType="CmmnMap">
        UPDATE employee
        SET password = #{col2}
        WHERE emp_seq = #{col1}
    </update>

    <!-- 로그인 검증 -->
    <select id="getUserByIdAndPassword" parameterType="CmmnMap" resultType="CmmnMap">
        SELECT *
        FROM employee
        WHERE employeeId = #{employeeId}
          AND password = #{password}
    </select>

</mapper>
