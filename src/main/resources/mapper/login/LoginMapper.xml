<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.kdt.KDT_PJT.login.mapper.LoginMapper">

    <!-- 로그인: 아이디 + 비밀번호로 사용자 조회 -->
    <select id="getUserByIdAndPassword" parameterType="CmmnMap" resultType="com.kdt.KDT_PJT.cmmn.map.EmployeeDto">
        SELECT emp_seq,
               employeeId, 
               active,
               deptName,
               position,
               role,
               emp_nm        
        FROM employee
        WHERE employeeId = #{employeeId}
          AND password = #{password}
    </select>

</mapper>
