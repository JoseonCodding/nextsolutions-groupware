<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.kdt.KDT_PJT.login.mapper.LoginMapper">

    <!-- 로그인: 아이디로 사용자 조회 (비밀번호는 서비스에서 BCrypt 비교) -->
    <select id="getUserById" parameterType="String" resultType="com.kdt.KDT_PJT.cmmn.map.EmployeeDto">
        SELECT emp_seq,
               employeeId,
               password,
               active,
               deptName,
               position,
               role,
               emp_nm,
               company_id AS companyId
        FROM employee
        WHERE employeeId = #{employeeId}
    </select>

</mapper>
