<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.kdt.KDT_PJT.login.mapper.LoginMapper">

    <select id="findByEmpNo" parameterType="String" resultType="com.kdt.KDT_PJT.login.dto.UserDTO">
        SELECT emp_no      AS empNo,
               emp_name    AS empName,
               dept_name   AS deptName,
               position    AS position,
               password,
               role,
               status
        FROM employee
        WHERE emp_no = #{empNo}
    </select>

</mapper>

